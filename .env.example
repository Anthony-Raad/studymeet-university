# Copy this file to a new file named ".env" and fill in your own values.
# The .env file should never be shared or committed to git, it has secrets in it.

# ---- MySQL database ----
# You need MySQL installed and running on your computer.
# Before you start the server, create the database with this SQL command:
#   CREATE DATABASE studymeet;
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-root-password
MYSQL_DATABASE=studymeet

# ---- Email (Mailjet) ----
# These are only needed if you want the app to actually send check-in emails.
# If you leave them blank the server still works, it just prints a message
# to the terminal instead of sending a real email.
# Get free API keys at https://www.mailjet.com (200 emails a day for free).
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
# This has to be an email address you verified on your Mailjet account.
SENDER_EMAIL=studymeet.university@example.com
# The web address people will use to open the server (used inside email links).
SERVER_URL=http://localhost:3000

# ---- AI summary (Google Gemini) ----
# Only needed if you want the "AI summary" feature after a meeting.
# Get a free key at https://aistudio.google.com  ->  "Get API key"
GEMINI_API_KEY=

# ---- Admin dashboard password ----
# Used to view /admin?pw=YOUR_PASSWORD in the browser.
ADMIN_PASSWORD=admin123
